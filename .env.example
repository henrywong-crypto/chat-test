# AWS / Cognito
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # optional, for assumed roles

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB table names
CONVERSATION_TABLE_NAME=bedrock-rs-conversations
BOT_TABLE_NAME=bedrock-rs-bots
INFERENCE_PROFILE_TABLE_NAME=bedrock-rs-inference-profiles

# S3 (optional — large message offload)
LARGE_MESSAGE_BUCKET=

# Server
SITE_ADDR=127.0.0.1:3000
RUST_LOG=info,app=debug

# Feature flags
ENABLE_APPLICATION_INFERENCE_PROFILES=true
ENABLE_GLOBAL_INFERENCE=false
ENABLE_CROSS_REGION_INFERENCE=false

# Local development (docker-compose)
# These override the AWS ones when docker-compose is running
DYNAMODB_ENDPOINT=http://localhost:8000
